---
/**
 * ============================================================================
 * ROTA DE TESTE — não é a home oficial.
 * URL: /home-animation-test
 *
 * Variação da home com hero cinemático (intro animado tipo Cleo, mas tema VP).
 * Tudo o resto da página é REUSADO da landing principal (problem, solution,
 * features, mockups, plans, trust, final CTA).
 *
 * Para promover essa variação, basta mover o conteúdo deste arquivo para
 * src/pages/index.astro e excluir/redirecionar este arquivo.
 * ============================================================================
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/landing.css";
import "../styles/landing-hero-cinematic.css";

import LandingHeroCinematic from "../components/home/landing/LandingHeroCinematic.astro";
import LandingFunctions from "../components/home/landing/LandingFunctions.astro";
import LandingSolution from "../components/home/landing/LandingSolution.astro";
import LandingMockups from "../components/home/landing/LandingMockups.astro";
import LandingFinalCta from "../components/home/landing/LandingFinalCta.astro";
---

<BaseLayout title="VistoPred — Teste de hero animado">
  <div class="lp-shell">
    <LandingHeroCinematic />
    <LandingFunctions />
    <LandingSolution />
    <LandingMockups />
    <LandingFinalCta />
  </div>
</BaseLayout>

<script>
  // Reveal-on-scroll para as seções abaixo do hero (mesmo da home oficial).
  const els = document.querySelectorAll<HTMLElement>("[data-lp-reveal]");
  if (els.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add("is-visible"));
  }

  // Flutuação contínua do celular após chegar na posição (1200ms+)
  const stage = document.querySelector<HTMLElement>(".lpc-phone-stage");
  if (stage && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    setTimeout(() => stage.classList.add("lpc-phone-stage--rest"), 1300);
  }
</script>
