---
import BaseLayout from "../layouts/BaseLayout.astro";

const variants = [
  { id: "stripe",      label: "01 · Stripe",       desc: "Sólido + gradient sutil + arrow on hover. Refinado, neutro." },
  { id: "vercel",      label: "02 · Vercel",       desc: "Flat sólido, sombra inset top, alto contraste. Minimal." },
  { id: "linear",      label: "03 · Linear",       desc: "Pill soft + gradient diagonal + highlight inset. Premium." },
  { id: "apple",       label: "04 · Apple iOS",    desc: "Pill cheio, sólido, sem sombra. Clean." },
  { id: "raycast",     label: "05 · Raycast",      desc: "Gradient + glow externo + inset top. Tátil, vibrante." },
  { id: "glass",       label: "06 · Glass (iOS)",  desc: "Translúcido com blur, borda hairline + highlight." },
  { id: "outline",     label: "07 · Outline fill", desc: "Borda + texto cyan, preenche no hover. Discreto." },
  { id: "neon",        label: "08 · Neon",         desc: "Dark fill + borda cyan + glow neon. Tech / cyber." },
  { id: "border-grad", label: "09 · Border gradient", desc: "Borda gradiente animada + fill dark. Moderno." },
  { id: "shine",       label: "10 · Shine sweep",  desc: "Gradient + flash atravessa no hover. Cinematográfico." },
  { id: "cohere",      label: "11 · Cohere",       desc: "Quase flat, borda hairline + dot indicador. Sóbrio." },
  { id: "notion",      label: "12 · Notion",       desc: "Flat 8px corners + sombra discreta + ícone." },
  { id: "tesla",       label: "13 · Tesla",        desc: "Uppercase, sharp rect, borda inferior grossa. Brutalista." },
  { id: "spotify",     label: "14 · Spotify",      desc: "Pill bold + scale + glow no hover. Energético." },
  { id: "resend",      label: "15 · Resend",       desc: "Minimal cyan flat + arrow + transição rápida." },
  { id: "lovable",     label: "16 · Lovable",      desc: "Pill com sparkles ✨ aparecendo nos cantos." },
  { id: "brutalist",   label: "17 · Brutalist",    desc: "Borda preta grossa + sombra dura offset. Bold." },
  { id: "push3d",      label: "18 · 3D Push",      desc: "Bevel embaixo, comprime ao clicar. Tátil." },
  { id: "pulse-ring",  label: "19 · Pulse ring",   desc: "Outline ring pulsa pra fora continuamente." },
  { id: "magnetic",    label: "20 · Magnetic glow",desc: "Radial gradient segue o mouse internamente." },
  { id: "liquid",      label: "21 · Liquid morph", desc: "Border-radius anima organicamente." },
  { id: "underline",   label: "22 · Underline trail", desc: "Linha cyan cresce L→R abaixo do texto." },
  { id: "mesh",        label: "23 · Mesh gradient",desc: "Conic gradient girando atrás do texto." },
  { id: "frost-text",  label: "24 · Frost + grad text", desc: "Glass blur + gradient no texto." },
  { id: "split",       label: "25 · Two-tone split",   desc: "Metade cyan / metade blue. Diferente." },
  { id: "cursor",      label: "26 · Cursor",           desc: "Dark + texto com gradient chromatic." },
  { id: "figma",       label: "27 · Figma marks",      desc: "Flat + 4 quadradinhos coloridos nos cantos." },
  { id: "cal",         label: "28 · Cal ↗",            desc: "Gradient + seta diagonal up-right." },
  { id: "pinterest",   label: "29 · Pinterest chunky", desc: "Pill super-rounded, padding generoso, bold." },
  { id: "terminal",    label: "30 · Terminal",         desc: "Monospace, brackets `>`, retro tech." },
  { id: "liquid-grad", label: "31 · Liquid gradient",  desc: "Gradient deslizando continuamente como onda." },
  { id: "rot-dot",     label: "32 · Rotating dot",     desc: "Dot brilhante girando ao redor da borda." },
  { id: "ripple",      label: "33 · Ripple click",     desc: "Onda concêntrica ao clicar (material)." },
  { id: "dual-ring",   label: "34 · Dual ring expand", desc: "Anel duplo se expande pra fora no hover." },
  { id: "holo",        label: "35 · Holographic",      desc: "Gradient hologramático multicor (cyan→blue)." },
  { id: "chip",        label: "36 · Badge chip",       desc: "Pequeno chip 'NEW' no canto superior direito." },
  { id: "shimmer",     label: "37 · Glass shimmer",    desc: "Glass + brilho diagonal contínuo (loop)." },
  { id: "border-draw", label: "38 · Border draw",      desc: "Borda desenhada do canto ao hover (4 linhas)." },
  { id: "skew",        label: "39 · Skew parallel",    desc: "Forma paralelograma inclinada, texto reto." },
  { id: "layered",     label: "40 · Layered cards",    desc: "Camada de fundo deslocada visível atrás." },
  { id: "sweep-fill",  label: "41 · Sweep fill",       desc: "Fill desliza L→R no hover (cor diferente)." },
  { id: "reveal-up",   label: "42 · Text reveal",      desc: "Texto sobe e revela texto duplicado." },
  { id: "icon-morph",  label: "43 · Icon morph",       desc: "Ícone troca/anima no hover (→ vira ✓)." },
  { id: "outline-out", label: "44 · Outline outward",  desc: "Outline cresce pra fora do botão no hover." },
  { id: "breathe",     label: "45 · Inner breathe",    desc: "Glow interno respirando (loop suave)." },
  { id: "bounce",      label: "46 · Bouncy",           desc: "Scale com spring physics ao hover." },
  { id: "diag-split",  label: "47 · Diagonal split",   desc: "Metade cyan / metade blue na diagonal." },
  { id: "live-dot",    label: "48 · Live indicator",   desc: "Dot blinks como 'ao vivo' (ping)." },
  { id: "inset-grad",  label: "49 · Inset gradient",   desc: "Gradient dentro do botão com border externo." },
  { id: "stacked",     label: "50 · Stacked depth",    desc: "Bloco abaixo deslocado, vira deck 3D." },
];
---

<BaseLayout title="VistoPred — Teste de botões">
  <section class="btn-test">
    <div class="btn-test__inner">
      <h1 class="btn-test__title">10 variações de CTA</h1>
      <p class="btn-test__lead">
        Cada linha = um par: <strong>Solicitar demonstração</strong> (primário cyan/azul)
        + <strong>Falar no WhatsApp</strong> (verde). Mesma família visual em cada par.
      </p>

      {variants.map((v) => (
        <div class={`btn-row btn-row--${v.id}`}>
          <div class="btn-row__meta">
            <div class="btn-row__label">{v.label}</div>
            <div class="btn-row__desc">{v.desc}</div>
          </div>
          <div class="btn-row__demo">
            <a class={`bv bv--${v.id} bv--primary`} href="#">Solicitar demonstração</a>
            <a class={`bv bv--${v.id} bv--whats`} href="#">Falar no WhatsApp</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Layout da página de teste ===== */
  .btn-test {
    padding: 140px 24px 80px;
    background: var(--bg);
    min-height: 100vh;
  }
  .btn-test__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .btn-test__title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    color: var(--text);
    margin: 0 0 12px;
  }
  .btn-test__lead {
    color: var(--text-muted);
    font-size: 16px;
    margin: 0 0 40px;
    max-width: 720px;
  }
  .btn-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 24px;
    align-items: center;
    padding: 28px 0;
    border-top: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
  }
  .btn-row:last-child { border-bottom: 1px solid color-mix(in srgb, var(--text) 8%, transparent); }
  .btn-row__label {
    font-weight: 700;
    font-size: 14px;
    color: var(--text);
    margin-bottom: 4px;
  }
  .btn-row__desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .btn-row__demo {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }
  @media (max-width: 720px) {
    .btn-row { grid-template-columns: 1fr; gap: 12px; }
  }

  /* ===========================================================================
     BASE — variáveis compartilhadas
     =========================================================================== */
  .bv {
    --c-cyan: #38bdf8;
    --c-blue: #1d4ed8;
    --c-deep: #0f4dbe;
    --c-whats: #25d366;
    --c-whats-dark: #128c45;
    --r: 999px;

    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--r);
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 220ms ease, background 220ms ease, color 220ms ease, border-color 220ms ease;
    isolation: isolate;
    overflow: hidden;
    white-space: nowrap;
  }
  .bv:hover { transform: translateY(-1px); }
  .bv:active { transform: translateY(0); }

  /* ===========================================================================
     01 · STRIPE — sólido + gradient sutil + arrow após o texto
     =========================================================================== */
  .bv--stripe.bv--primary {
    background: linear-gradient(180deg, #3b82f6 0%, #1d4ed8 100%);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 4px 12px rgba(29,78,216,0.28);
  }
  .bv--stripe.bv--primary:hover {
    box-shadow: 0 1px 0 rgba(255,255,255,0.22) inset, 0 6px 18px rgba(29,78,216,0.36);
  }
  .bv--stripe.bv--primary::after { content: "→"; transition: transform 220ms ease; }
  .bv--stripe.bv--primary:hover::after { transform: translateX(4px); }

  .bv--stripe.bv--whats {
    background: linear-gradient(180deg, #2bd96f 0%, #128c45 100%);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 4px 12px rgba(18,140,69,0.28);
  }
  .bv--stripe.bv--whats:hover {
    box-shadow: 0 1px 0 rgba(255,255,255,0.22) inset, 0 6px 18px rgba(18,140,69,0.36);
  }
  .bv--stripe.bv--whats::after { content: "→"; transition: transform 220ms ease; }
  .bv--stripe.bv--whats:hover::after { transform: translateX(4px); }

  /* ===========================================================================
     02 · VERCEL — flat sólido, alto contraste, borda hairline
     =========================================================================== */
  .bv--vercel.bv--primary {
    background: var(--c-blue);
    color: #fff;
    border-color: rgba(255,255,255,0.12);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
    border-radius: 10px;
  }
  .bv--vercel.bv--primary:hover { background: #1e3aa8; }

  .bv--vercel.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
    border-color: rgba(255,255,255,0.12);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
    border-radius: 10px;
  }
  .bv--vercel.bv--whats:hover { background: #0e7037; }

  /* ===========================================================================
     03 · LINEAR — pill + gradient diagonal + highlight inset
     =========================================================================== */
  .bv--linear.bv--primary {
    background: linear-gradient(135deg, #38bdf8 0%, #1d4ed8 100%);
    color: #fff;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.25),
      inset 0 -1px 0 rgba(0,0,0,0.15),
      0 4px 14px rgba(56,189,248,0.25);
  }
  .bv--linear.bv--primary:hover {
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.32),
      inset 0 -1px 0 rgba(0,0,0,0.15),
      0 8px 24px rgba(56,189,248,0.4);
  }

  .bv--linear.bv--whats {
    background: linear-gradient(135deg, #2bd96f 0%, #0e7037 100%);
    color: #fff;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.25),
      inset 0 -1px 0 rgba(0,0,0,0.15),
      0 4px 14px rgba(37,211,102,0.25);
  }
  .bv--linear.bv--whats:hover {
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.32),
      inset 0 -1px 0 rgba(0,0,0,0.15),
      0 8px 24px rgba(37,211,102,0.4);
  }

  /* ===========================================================================
     04 · APPLE iOS — pill cheio sólido, sem sombra
     =========================================================================== */
  .bv--apple.bv--primary {
    background: var(--c-cyan);
    color: #0f172a;
    font-weight: 700;
  }
  .bv--apple.bv--primary:hover { background: #7dd3fc; }

  .bv--apple.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 700;
  }
  .bv--apple.bv--whats:hover { background: #4ade80; }

  /* ===========================================================================
     05 · RAYCAST — gradient + glow externo + inset top
     =========================================================================== */
  .bv--raycast.bv--primary {
    background: linear-gradient(180deg, #60a5fa 0%, #1d4ed8 100%);
    color: #fff;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.4),
      inset 0 -2px 0 rgba(15,77,190,0.6),
      0 0 24px rgba(56,189,248,0.45),
      0 8px 20px rgba(29,78,216,0.35);
  }
  .bv--raycast.bv--primary:hover {
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.5),
      inset 0 -2px 0 rgba(15,77,190,0.6),
      0 0 36px rgba(56,189,248,0.7),
      0 12px 28px rgba(29,78,216,0.5);
  }

  .bv--raycast.bv--whats {
    background: linear-gradient(180deg, #4ade80 0%, #128c45 100%);
    color: #fff;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.4),
      inset 0 -2px 0 rgba(7,90,44,0.6),
      0 0 24px rgba(37,211,102,0.45),
      0 8px 20px rgba(18,140,69,0.35);
  }
  .bv--raycast.bv--whats:hover {
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.5),
      inset 0 -2px 0 rgba(7,90,44,0.6),
      0 0 36px rgba(37,211,102,0.7),
      0 12px 28px rgba(18,140,69,0.5);
  }

  /* ===========================================================================
     06 · GLASS (iOS) — translúcido com blur
     =========================================================================== */
  .bv--glass.bv--primary {
    background: color-mix(in srgb, var(--c-cyan) 22%, transparent);
    color: var(--text);
    border-color: color-mix(in srgb, var(--c-cyan) 55%, transparent);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 4px 16px rgba(56,189,248,0.15);
  }
  .bv--glass.bv--primary:hover {
    background: color-mix(in srgb, var(--c-cyan) 32%, transparent);
    border-color: var(--c-cyan);
  }

  .bv--glass.bv--whats {
    background: color-mix(in srgb, var(--c-whats) 22%, transparent);
    color: var(--text);
    border-color: color-mix(in srgb, var(--c-whats) 55%, transparent);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 4px 16px rgba(37,211,102,0.15);
  }
  .bv--glass.bv--whats:hover {
    background: color-mix(in srgb, var(--c-whats) 32%, transparent);
    border-color: var(--c-whats);
  }

  /* ===========================================================================
     07 · OUTLINE fill — borda + texto cyan, preenche no hover
     =========================================================================== */
  .bv--outline.bv--primary {
    background: transparent;
    color: var(--c-cyan);
    border: 1.5px solid var(--c-cyan);
  }
  .bv--outline.bv--primary:hover {
    background: var(--c-cyan);
    color: #0f172a;
    box-shadow: 0 6px 20px rgba(56,189,248,0.35);
  }

  .bv--outline.bv--whats {
    background: transparent;
    color: var(--c-whats);
    border: 1.5px solid var(--c-whats);
  }
  .bv--outline.bv--whats:hover {
    background: var(--c-whats);
    color: #06281a;
    box-shadow: 0 6px 20px rgba(37,211,102,0.35);
  }

  /* ===========================================================================
     08 · NEON — dark fill + borda cyan + glow neon
     =========================================================================== */
  .bv--neon.bv--primary {
    background: #0b1220;
    color: var(--c-cyan);
    border: 1px solid var(--c-cyan);
    box-shadow:
      0 0 0 1px rgba(56,189,248,0.25),
      0 0 18px rgba(56,189,248,0.55),
      inset 0 0 12px rgba(56,189,248,0.18);
    text-shadow: 0 0 8px rgba(56,189,248,0.6);
  }
  .bv--neon.bv--primary:hover {
    background: #0f1a2e;
    box-shadow:
      0 0 0 1px rgba(56,189,248,0.4),
      0 0 28px rgba(56,189,248,0.85),
      inset 0 0 16px rgba(56,189,248,0.28);
  }

  .bv--neon.bv--whats {
    background: #0b1220;
    color: var(--c-whats);
    border: 1px solid var(--c-whats);
    box-shadow:
      0 0 0 1px rgba(37,211,102,0.25),
      0 0 18px rgba(37,211,102,0.55),
      inset 0 0 12px rgba(37,211,102,0.18);
    text-shadow: 0 0 8px rgba(37,211,102,0.6);
  }
  .bv--neon.bv--whats:hover {
    background: #0f1f15;
    box-shadow:
      0 0 0 1px rgba(37,211,102,0.4),
      0 0 28px rgba(37,211,102,0.85),
      inset 0 0 16px rgba(37,211,102,0.28);
  }

  /* ===========================================================================
     09 · BORDER GRADIENT — borda gradiente animada + fill dark
     =========================================================================== */
  .bv--border-grad.bv--primary,
  .bv--border-grad.bv--whats {
    background: #0b1220;
    color: #fff;
    border: none;
    padding: 15px 25px;
  }
  .bv--border-grad.bv--primary::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(120deg, #38bdf8, #1d4ed8, #38bdf8);
    background-size: 200% 100%;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    animation: bvSlide 3.5s linear infinite;
    z-index: -1;
  }
  .bv--border-grad.bv--whats::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(120deg, #2bd96f, #128c45, #2bd96f);
    background-size: 200% 100%;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    animation: bvSlide 3.5s linear infinite;
    z-index: -1;
  }
  @keyframes bvSlide {
    to { background-position: -200% 0; }
  }
  .bv--border-grad.bv--primary:hover { box-shadow: 0 0 24px rgba(56,189,248,0.4); }
  .bv--border-grad.bv--whats:hover { box-shadow: 0 0 24px rgba(37,211,102,0.4); }

  /* ===========================================================================
     10 · SHINE SWEEP — gradient + flash branco que atravessa no hover
     =========================================================================== */
  .bv--shine.bv--primary {
    background: linear-gradient(135deg, #38bdf8 0%, #1d4ed8 100%);
    color: #fff;
    box-shadow: 0 6px 18px rgba(29,78,216,0.32);
  }
  .bv--shine.bv--primary::before,
  .bv--shine.bv--whats::before {
    content: "";
    position: absolute;
    top: 0; left: -120%;
    width: 60%; height: 100%;
    background: linear-gradient(110deg, transparent 20%, rgba(255,255,255,0.55) 50%, transparent 80%);
    transform: skewX(-20deg);
    transition: left 700ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .bv--shine.bv--primary:hover::before,
  .bv--shine.bv--whats:hover::before { left: 130%; }

  .bv--shine.bv--whats {
    background: linear-gradient(135deg, #2bd96f 0%, #0e7037 100%);
    color: #fff;
    box-shadow: 0 6px 18px rgba(18,140,69,0.32);
  }

  /* ===========================================================================
     11 · COHERE — quase flat, borda hairline + dot indicador
     =========================================================================== */
  .bv--cohere.bv--primary {
    background: color-mix(in srgb, var(--c-cyan) 12%, transparent);
    color: var(--c-blue);
    border: 1px solid color-mix(in srgb, var(--c-cyan) 35%, transparent);
    font-weight: 600;
  }
  .bv--cohere.bv--primary::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-cyan); box-shadow: 0 0 6px var(--c-cyan);
  }
  .bv--cohere.bv--primary:hover { background: color-mix(in srgb, var(--c-cyan) 22%, transparent); border-color: var(--c-cyan); }

  .bv--cohere.bv--whats {
    background: color-mix(in srgb, var(--c-whats) 12%, transparent);
    color: var(--c-whats-dark);
    border: 1px solid color-mix(in srgb, var(--c-whats) 35%, transparent);
    font-weight: 600;
  }
  .bv--cohere.bv--whats::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-whats); box-shadow: 0 0 6px var(--c-whats);
  }
  .bv--cohere.bv--whats:hover { background: color-mix(in srgb, var(--c-whats) 22%, transparent); border-color: var(--c-whats); }

  /* ===========================================================================
     12 · NOTION — flat 8px + sombra discreta + ícone
     =========================================================================== */
  .bv--notion.bv--primary {
    background: var(--c-blue);
    color: #fff;
    border-radius: 8px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.12), 0 4px 8px rgba(29,78,216,0.18);
  }
  .bv--notion.bv--primary::before { content: "▶"; font-size: 10px; }
  .bv--notion.bv--primary:hover { background: #1e3aa8; box-shadow: 0 2px 4px rgba(15,23,42,0.15), 0 6px 14px rgba(29,78,216,0.28); }

  .bv--notion.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
    border-radius: 8px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.12), 0 4px 8px rgba(18,140,69,0.18);
  }
  .bv--notion.bv--whats::before { content: "✆"; font-size: 13px; }
  .bv--notion.bv--whats:hover { background: #0e7037; box-shadow: 0 2px 4px rgba(15,23,42,0.15), 0 6px 14px rgba(18,140,69,0.28); }

  /* ===========================================================================
     13 · TESLA — uppercase, sharp rect, borda inferior grossa
     =========================================================================== */
  .bv--tesla.bv--primary {
    background: var(--c-cyan);
    color: #0f172a;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 13px;
    font-weight: 700;
    border-bottom: 3px solid var(--c-deep);
    padding: 13px 26px 11px;
  }
  .bv--tesla.bv--primary:hover { background: #7dd3fc; }

  .bv--tesla.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 13px;
    font-weight: 700;
    border-bottom: 3px solid var(--c-whats-dark);
    padding: 13px 26px 11px;
  }
  .bv--tesla.bv--whats:hover { background: #4ade80; }

  /* ===========================================================================
     14 · SPOTIFY — pill bold + scale + glow on hover
     =========================================================================== */
  .bv--spotify.bv--primary {
    background: var(--c-cyan);
    color: #0f172a;
    font-weight: 800;
    letter-spacing: 0.3px;
    padding: 16px 32px;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 200ms ease;
  }
  .bv--spotify.bv--primary:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 28px rgba(56,189,248,0.55);
  }

  .bv--spotify.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 800;
    letter-spacing: 0.3px;
    padding: 16px 32px;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 200ms ease;
  }
  .bv--spotify.bv--whats:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 28px rgba(37,211,102,0.55);
  }

  /* ===========================================================================
     15 · RESEND — minimal flat + arrow + fast transition
     =========================================================================== */
  .bv--resend.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    border-radius: 6px;
    font-weight: 600;
    transition: background 120ms ease, transform 120ms ease;
  }
  .bv--resend.bv--primary::after { content: "→"; }
  .bv--resend.bv--primary:hover { background: #7dd3fc; }

  .bv--resend.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    border-radius: 6px;
    font-weight: 600;
    transition: background 120ms ease, transform 120ms ease;
  }
  .bv--resend.bv--whats::after { content: "→"; }
  .bv--resend.bv--whats:hover { background: #4ade80; }

  /* ===========================================================================
     16 · LOVABLE — pill + sparkles aparecendo
     =========================================================================== */
  .bv--lovable.bv--primary {
    background: linear-gradient(135deg, #38bdf8 0%, #1d4ed8 100%);
    color: #fff;
    box-shadow: 0 4px 16px rgba(56,189,248,0.35);
  }
  .bv--lovable.bv--primary::before { content: "✨"; font-size: 12px; opacity: 0; transition: opacity 250ms ease, transform 350ms ease; transform: scale(0.5) rotate(-20deg); }
  .bv--lovable.bv--primary::after  { content: "✨"; font-size: 10px; opacity: 0; transition: opacity 300ms ease 60ms, transform 400ms ease 60ms; transform: scale(0.5) rotate(20deg); }
  .bv--lovable.bv--primary:hover::before,
  .bv--lovable.bv--primary:hover::after { opacity: 1; transform: scale(1) rotate(0); }

  .bv--lovable.bv--whats {
    background: linear-gradient(135deg, #2bd96f 0%, #128c45 100%);
    color: #fff;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
  }
  .bv--lovable.bv--whats::before { content: "💬"; font-size: 12px; opacity: 0; transition: opacity 250ms ease, transform 350ms ease; transform: scale(0.5) rotate(-20deg); }
  .bv--lovable.bv--whats::after  { content: "✨"; font-size: 10px; opacity: 0; transition: opacity 300ms ease 60ms, transform 400ms ease 60ms; transform: scale(0.5) rotate(20deg); }
  .bv--lovable.bv--whats:hover::before,
  .bv--lovable.bv--whats:hover::after { opacity: 1; transform: scale(1) rotate(0); }

  /* ===========================================================================
     17 · BRUTALIST — borda preta + sombra dura offset
     =========================================================================== */
  .bv--brutalist.bv--primary {
    background: var(--c-cyan);
    color: #0f172a;
    border: 2px solid #0f172a;
    border-radius: 6px;
    font-weight: 800;
    box-shadow: 4px 4px 0 #0f172a;
    transition: transform 120ms ease, box-shadow 120ms ease;
  }
  .bv--brutalist.bv--primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #0f172a; }
  .bv--brutalist.bv--primary:active { transform: translate(2px, 2px); box-shadow: 0 0 0 #0f172a; }

  .bv--brutalist.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    border: 2px solid #0f172a;
    border-radius: 6px;
    font-weight: 800;
    box-shadow: 4px 4px 0 #0f172a;
    transition: transform 120ms ease, box-shadow 120ms ease;
  }
  .bv--brutalist.bv--whats:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #0f172a; }
  .bv--brutalist.bv--whats:active { transform: translate(2px, 2px); box-shadow: 0 0 0 #0f172a; }

  /* ===========================================================================
     18 · 3D PUSH — bevel embaixo, comprime ao clicar
     =========================================================================== */
  .bv--push3d.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    border-radius: 12px;
    font-weight: 700;
    box-shadow: 0 5px 0 var(--c-deep), 0 6px 16px rgba(15,77,190,0.3);
    transition: transform 100ms ease, box-shadow 100ms ease;
  }
  .bv--push3d.bv--primary:hover { transform: translateY(-1px); box-shadow: 0 6px 0 var(--c-deep), 0 8px 22px rgba(15,77,190,0.4); }
  .bv--push3d.bv--primary:active { transform: translateY(4px); box-shadow: 0 1px 0 var(--c-deep), 0 2px 6px rgba(15,77,190,0.3); }

  .bv--push3d.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    border-radius: 12px;
    font-weight: 700;
    box-shadow: 0 5px 0 var(--c-whats-dark), 0 6px 16px rgba(7,90,44,0.3);
    transition: transform 100ms ease, box-shadow 100ms ease;
  }
  .bv--push3d.bv--whats:hover { transform: translateY(-1px); box-shadow: 0 6px 0 var(--c-whats-dark), 0 8px 22px rgba(7,90,44,0.4); }
  .bv--push3d.bv--whats:active { transform: translateY(4px); box-shadow: 0 1px 0 var(--c-whats-dark), 0 2px 6px rgba(7,90,44,0.3); }

  /* ===========================================================================
     19 · PULSE RING — outline pulsa pra fora
     =========================================================================== */
  .bv--pulse-ring.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    box-shadow: 0 0 0 0 rgba(56,189,248,0.7);
    animation: bvPulseCyan 2s infinite;
  }
  @keyframes bvPulseCyan {
    0%   { box-shadow: 0 0 0 0 rgba(56,189,248,0.55); }
    70%  { box-shadow: 0 0 0 14px rgba(56,189,248,0); }
    100% { box-shadow: 0 0 0 0 rgba(56,189,248,0); }
  }

  .bv--pulse-ring.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    box-shadow: 0 0 0 0 rgba(37,211,102,0.7);
    animation: bvPulseGreen 2s infinite;
  }
  @keyframes bvPulseGreen {
    0%   { box-shadow: 0 0 0 0 rgba(37,211,102,0.55); }
    70%  { box-shadow: 0 0 0 14px rgba(37,211,102,0); }
    100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
  }

  /* ===========================================================================
     20 · MAGNETIC GLOW — radial gradient segue mouse (via CSS var --mx/--my)
     =========================================================================== */
  .bv--magnetic.bv--primary,
  .bv--magnetic.bv--whats {
    background: #0b1220;
    color: #fff;
    border: 1px solid color-mix(in srgb, var(--c-cyan) 30%, transparent);
  }
  .bv--magnetic.bv--primary {
    background:
      radial-gradient(120px circle at var(--mx, 50%) var(--my, 50%), rgba(56,189,248,0.55), transparent 60%),
      #0b1220;
  }
  .bv--magnetic.bv--whats {
    background:
      radial-gradient(120px circle at var(--mx, 50%) var(--my, 50%), rgba(37,211,102,0.55), transparent 60%),
      #0b1220;
    border-color: color-mix(in srgb, var(--c-whats) 30%, transparent);
  }

  /* ===========================================================================
     21 · LIQUID MORPH — border-radius anima organicamente
     =========================================================================== */
  .bv--liquid.bv--primary {
    background: linear-gradient(135deg, #38bdf8, #1d4ed8);
    color: #fff;
    border-radius: 30% 70% 70% 30% / 50% 50% 50% 50%;
    transition: border-radius 600ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 300ms ease;
    box-shadow: 0 6px 22px rgba(56,189,248,0.35);
  }
  .bv--liquid.bv--primary:hover { border-radius: 70% 30% 50% 50% / 30% 50% 50% 70%; }

  .bv--liquid.bv--whats {
    background: linear-gradient(135deg, #2bd96f, #128c45);
    color: #fff;
    border-radius: 30% 70% 70% 30% / 50% 50% 50% 50%;
    transition: border-radius 600ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 300ms ease;
    box-shadow: 0 6px 22px rgba(37,211,102,0.35);
  }
  .bv--liquid.bv--whats:hover { border-radius: 70% 30% 50% 50% / 30% 50% 50% 70%; }

  /* ===========================================================================
     22 · UNDERLINE TRAIL — linha cresce abaixo do texto
     =========================================================================== */
  .bv--underline.bv--primary,
  .bv--underline.bv--whats {
    background: transparent;
    border-radius: 0;
    padding: 14px 8px;
    overflow: visible;
  }
  .bv--underline.bv--primary { color: var(--c-cyan); }
  .bv--underline.bv--whats   { color: var(--c-whats); }
  .bv--underline.bv--primary::after,
  .bv--underline.bv--whats::after {
    content: "";
    position: absolute;
    left: 8px; right: 8px;
    bottom: 6px;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 360ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .bv--underline.bv--primary::after { background: linear-gradient(90deg, var(--c-cyan), var(--c-blue)); }
  .bv--underline.bv--whats::after   { background: linear-gradient(90deg, var(--c-whats), var(--c-whats-dark)); }
  .bv--underline.bv--primary:hover::after,
  .bv--underline.bv--whats:hover::after { transform: scaleX(1); }

  /* ===========================================================================
     23 · MESH — conic gradient girando atrás
     =========================================================================== */
  .bv--mesh.bv--primary,
  .bv--mesh.bv--whats {
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .bv--mesh.bv--primary::before,
  .bv--mesh.bv--whats::before {
    content: "";
    position: absolute;
    inset: -50%;
    z-index: -1;
    animation: bvSpin 6s linear infinite;
  }
  .bv--mesh.bv--primary::before {
    background: conic-gradient(from 0deg, #38bdf8, #1d4ed8, #0ea5e9, #1d4ed8, #38bdf8);
  }
  .bv--mesh.bv--whats::before {
    background: conic-gradient(from 0deg, #2bd96f, #128c45, #16a34a, #128c45, #2bd96f);
  }
  @keyframes bvSpin { to { transform: rotate(360deg); } }

  /* ===========================================================================
     24 · FROST + GRADIENT TEXT
     =========================================================================== */
  .bv--frost-text.bv--primary {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(56,189,248,0.4);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    background-image: linear-gradient(135deg, var(--c-cyan), var(--c-blue));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
  }
  .bv--frost-text.bv--primary:hover { border-color: var(--c-cyan); box-shadow: 0 0 24px rgba(56,189,248,0.3); }

  .bv--frost-text.bv--whats {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(37,211,102,0.4);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    background-image: linear-gradient(135deg, var(--c-whats), var(--c-whats-dark));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
  }
  .bv--frost-text.bv--whats:hover { border-color: var(--c-whats); box-shadow: 0 0 24px rgba(37,211,102,0.3); }

  /* ===========================================================================
     25 · TWO-TONE SPLIT — metade cyan, metade blue
     =========================================================================== */
  .bv--split.bv--primary {
    background: linear-gradient(90deg, var(--c-cyan) 0%, var(--c-cyan) 50%, var(--c-blue) 50%, var(--c-blue) 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(29,78,216,0.3);
    transition: background-size 600ms ease, transform 200ms ease;
    background-size: 200% 100%;
    background-position: 50% 0;
  }
  .bv--split.bv--primary:hover { background-position: 0 0; }

  .bv--split.bv--whats {
    background: linear-gradient(90deg, #2bd96f 0%, #2bd96f 50%, #128c45 50%, #128c45 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(18,140,69,0.3);
    transition: background-size 600ms ease, transform 200ms ease;
    background-size: 200% 100%;
    background-position: 50% 0;
  }
  .bv--split.bv--whats:hover { background-position: 0 0; }

  /* ===========================================================================
     26 · CURSOR — dark + texto gradient chromatic
     =========================================================================== */
  .bv--cursor.bv--primary,
  .bv--cursor.bv--whats {
    background: #0a0e1a;
    color: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    font-weight: 700;
  }
  .bv--cursor.bv--primary {
    background-image: linear-gradient(90deg, #67e8f9, #38bdf8, #1d4ed8);
    -webkit-background-clip: text; background-clip: text;
  }
  .bv--cursor.bv--whats {
    background-image: linear-gradient(90deg, #86efac, #2bd96f, #128c45);
    -webkit-background-clip: text; background-clip: text;
  }
  .bv--cursor.bv--primary::before,
  .bv--cursor.bv--whats::before {
    content: ""; position: absolute; inset: 0; background: #0a0e1a; border-radius: inherit; z-index: -1;
  }
  .bv--cursor.bv--primary:hover { border-color: var(--c-cyan); box-shadow: 0 0 24px rgba(56,189,248,0.25); }
  .bv--cursor.bv--whats:hover   { border-color: var(--c-whats); box-shadow: 0 0 24px rgba(37,211,102,0.25); }

  /* ===========================================================================
     27 · FIGMA marks — flat + 4 quadrados coloridos nos cantos
     =========================================================================== */
  .bv--figma.bv--primary,
  .bv--figma.bv--whats {
    background: #fff;
    color: #0f172a;
    border-radius: 8px;
    border: 1px solid rgba(15,23,42,0.1);
    box-shadow: 0 2px 6px rgba(15,23,42,0.08);
  }
  .bv--figma.bv--primary { box-shadow:
    -3px -3px 0 #38bdf8, 3px -3px 0 #1d4ed8,
    -3px 3px 0 #1d4ed8, 3px 3px 0 #38bdf8,
    0 0 0 1px rgba(15,23,42,0.06);
  }
  .bv--figma.bv--whats { box-shadow:
    -3px -3px 0 #2bd96f, 3px -3px 0 #128c45,
    -3px 3px 0 #128c45, 3px 3px 0 #2bd96f,
    0 0 0 1px rgba(15,23,42,0.06);
  }
  .bv--figma.bv--primary:hover,
  .bv--figma.bv--whats:hover { transform: translateY(-2px); }

  /* ===========================================================================
     28 · CAL ↗ — gradient + seta diagonal up-right
     =========================================================================== */
  .bv--cal.bv--primary {
    background: linear-gradient(135deg, #38bdf8, #1d4ed8);
    color: #fff;
    box-shadow: 0 6px 18px rgba(29,78,216,0.3);
  }
  .bv--cal.bv--primary::after { content: "↗"; transition: transform 280ms ease; font-size: 16px; }
  .bv--cal.bv--primary:hover::after { transform: translate(3px, -3px); }

  .bv--cal.bv--whats {
    background: linear-gradient(135deg, #2bd96f, #128c45);
    color: #fff;
    box-shadow: 0 6px 18px rgba(18,140,69,0.3);
  }
  .bv--cal.bv--whats::after { content: "↗"; transition: transform 280ms ease; font-size: 16px; }
  .bv--cal.bv--whats:hover::after { transform: translate(3px, -3px); }

  /* ===========================================================================
     29 · PINTEREST chunky — pill super-rounded, padding grande
     =========================================================================== */
  .bv--pinterest.bv--primary {
    background: var(--c-blue);
    color: #fff;
    padding: 18px 36px;
    font-weight: 800;
    font-size: 16px;
  }
  .bv--pinterest.bv--primary:hover { background: #1e3aa8; box-shadow: 0 10px 30px rgba(29,78,216,0.35); }

  .bv--pinterest.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
    padding: 18px 36px;
    font-weight: 800;
    font-size: 16px;
  }
  .bv--pinterest.bv--whats:hover { background: #0e7037; box-shadow: 0 10px 30px rgba(18,140,69,0.35); }

  /* ===========================================================================
     30 · TERMINAL — monospace + brackets > _
     =========================================================================== */
  .bv--terminal.bv--primary,
  .bv--terminal.bv--whats {
    background: #050a14;
    border: 1px solid var(--c-cyan);
    color: var(--c-cyan);
    font-family: ui-monospace, "SF Mono", "Cascadia Code", "Fira Code", monospace;
    font-size: 13px;
    font-weight: 600;
    border-radius: 4px;
    padding: 14px 20px;
    letter-spacing: 0.5px;
  }
  .bv--terminal.bv--whats { border-color: var(--c-whats); color: var(--c-whats); }
  .bv--terminal.bv--primary::before { content: ">"; opacity: 0.6; }
  .bv--terminal.bv--whats::before   { content: ">"; opacity: 0.6; }
  .bv--terminal.bv--primary::after  { content: "_"; opacity: 1; animation: bvBlink 1s steps(2) infinite; }
  .bv--terminal.bv--whats::after    { content: "_"; opacity: 1; animation: bvBlink 1s steps(2) infinite; }
  @keyframes bvBlink { 50% { opacity: 0; } }
  .bv--terminal.bv--primary:hover { background: #0a1428; box-shadow: 0 0 20px rgba(56,189,248,0.4); }
  .bv--terminal.bv--whats:hover   { background: #0a1f15; box-shadow: 0 0 20px rgba(37,211,102,0.4); }

  /* ===========================================================================
     31 · LIQUID GRADIENT — gradient deslizando continuamente
     =========================================================================== */
  .bv--liquid-grad.bv--primary {
    background: linear-gradient(90deg, #38bdf8, #1d4ed8, #0ea5e9, #38bdf8);
    background-size: 300% 100%;
    color: #fff;
    animation: bvSlideBg 4s linear infinite;
    box-shadow: 0 6px 20px rgba(56,189,248,0.35);
  }
  .bv--liquid-grad.bv--whats {
    background: linear-gradient(90deg, #2bd96f, #128c45, #16a34a, #2bd96f);
    background-size: 300% 100%;
    color: #fff;
    animation: bvSlideBg 4s linear infinite;
    box-shadow: 0 6px 20px rgba(37,211,102,0.35);
  }
  @keyframes bvSlideBg { to { background-position: -300% 0; } }

  /* ===========================================================================
     32 · ROTATING DOT — dot girando ao redor da borda
     =========================================================================== */
  .bv--rot-dot.bv--primary,
  .bv--rot-dot.bv--whats {
    background: #0b1220;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .bv--rot-dot.bv--primary::before,
  .bv--rot-dot.bv--whats::before {
    content: ""; position: absolute; inset: -2px; border-radius: inherit;
    z-index: -1;
    background: conic-gradient(from 0deg, transparent 0deg, transparent 320deg, var(--c-cyan) 360deg);
    animation: bvSpin 2.5s linear infinite;
    filter: blur(2px);
  }
  .bv--rot-dot.bv--whats::before {
    background: conic-gradient(from 0deg, transparent 0deg, transparent 320deg, var(--c-whats) 360deg);
  }

  /* ===========================================================================
     33 · RIPPLE click — onda concêntrica ao clicar
     =========================================================================== */
  .bv--ripple.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    font-weight: 700;
  }
  .bv--ripple.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 700;
  }
  .bv--ripple.bv--primary::after,
  .bv--ripple.bv--whats::after {
    content: ""; position: absolute; left: 50%; top: 50%;
    width: 0; height: 0; border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transform: translate(-50%, -50%);
    transition: width 600ms ease, height 600ms ease, opacity 600ms ease;
    opacity: 0;
  }
  .bv--ripple.bv--primary:active::after,
  .bv--ripple.bv--whats:active::after { width: 300px; height: 300px; opacity: 1; transition: 0s; }

  /* ===========================================================================
     34 · DUAL RING expand — 2 anéis crescem pra fora no hover
     =========================================================================== */
  .bv--dual-ring.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    font-weight: 700;
    box-shadow: 0 0 0 0 rgba(56,189,248,0), 0 0 0 0 rgba(56,189,248,0);
    transition: box-shadow 400ms ease;
  }
  .bv--dual-ring.bv--primary:hover {
    box-shadow: 0 0 0 6px rgba(56,189,248,0.25), 0 0 0 12px rgba(56,189,248,0.12);
  }
  .bv--dual-ring.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 700;
    transition: box-shadow 400ms ease;
  }
  .bv--dual-ring.bv--whats:hover {
    box-shadow: 0 0 0 6px rgba(37,211,102,0.25), 0 0 0 12px rgba(37,211,102,0.12);
  }

  /* ===========================================================================
     35 · HOLOGRAPHIC — gradient hologramático multitom
     =========================================================================== */
  .bv--holo.bv--primary {
    /* Gradient começa e termina na MESMA cor (#67e8f9). Combinado com
       background-size: 200% e keyframe 0→-100%, o loop é perfeitamente
       seamless — o ponto final do ciclo bate com o inicial. */
    background: linear-gradient(110deg, #67e8f9, #38bdf8, #3b82f6, #1d4ed8, #38bdf8, #67e8f9);
    background-size: 200% 100%;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    animation: bvHoloLoop 6s linear infinite;
    box-shadow: 0 8px 24px rgba(56,189,248,0.4), inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .bv--holo.bv--whats {
    background: linear-gradient(110deg, #86efac, #4ade80, #22c55e, #128c45, #2bd96f, #86efac);
    background-size: 200% 100%;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    animation: bvHoloLoop 6s linear infinite;
    box-shadow: 0 8px 24px rgba(37,211,102,0.4), inset 0 1px 0 rgba(255,255,255,0.3);
  }
  @keyframes bvHoloLoop {
    from { background-position: 0% 0; }
    to   { background-position: -100% 0; }
  }

  /* ===========================================================================
     36 · BADGE chip — pequeno "NEW" no canto
     =========================================================================== */
  .bv--chip.bv--primary,
  .bv--chip.bv--whats {
    overflow: visible;
    padding-right: 30px;
  }
  .bv--chip.bv--primary {
    background: var(--c-blue);
    color: #fff;
  }
  .bv--chip.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
  }
  .bv--chip.bv--primary::after,
  .bv--chip.bv--whats::after {
    content: "NEW";
    position: absolute;
    top: -8px;
    right: -6px;
    background: var(--c-cyan);
    color: #0a1628;
    font-size: 9px;
    font-weight: 800;
    padding: 3px 6px;
    border-radius: 10px;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 6px rgba(56,189,248,0.5);
  }
  .bv--chip.bv--whats::after { background: var(--c-whats); }

  /* ===========================================================================
     37 · GLASS SHIMMER — glass + brilho diagonal contínuo
     =========================================================================== */
  .bv--shimmer.bv--primary,
  .bv--shimmer.bv--whats {
    background: rgba(15,23,42,0.4);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .bv--shimmer.bv--primary { border-color: rgba(56,189,248,0.4); }
  .bv--shimmer.bv--whats   { border-color: rgba(37,211,102,0.4); }
  .bv--shimmer.bv--primary::before,
  .bv--shimmer.bv--whats::before {
    content: ""; position: absolute; top: 0; left: -100%;
    width: 50%; height: 100%;
    background: linear-gradient(110deg, transparent 30%, rgba(255,255,255,0.4) 50%, transparent 70%);
    animation: bvShimmer 2.5s ease-in-out infinite;
    transform: skewX(-20deg);
    pointer-events: none;
  }
  @keyframes bvShimmer { 0% { left: -100%; } 100% { left: 200%; } }

  /* ===========================================================================
     38 · BORDER DRAW — borda desenhada do canto no hover
     =========================================================================== */
  .bv--border-draw.bv--primary,
  .bv--border-draw.bv--whats {
    background: transparent;
    border-radius: 4px;
  }
  .bv--border-draw.bv--primary { color: var(--c-cyan); }
  .bv--border-draw.bv--whats   { color: var(--c-whats); }
  .bv--border-draw.bv--primary::before,
  .bv--border-draw.bv--whats::before,
  .bv--border-draw.bv--primary::after,
  .bv--border-draw.bv--whats::after {
    content: ""; position: absolute;
    transition: all 350ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bv--border-draw.bv--primary::before,
  .bv--border-draw.bv--whats::before {
    top: 0; left: 0; width: 0; height: 1.5px;
  }
  .bv--border-draw.bv--primary::after,
  .bv--border-draw.bv--whats::after {
    bottom: 0; right: 0; width: 0; height: 1.5px;
  }
  .bv--border-draw.bv--primary::before,
  .bv--border-draw.bv--primary::after { background: var(--c-cyan); }
  .bv--border-draw.bv--whats::before,
  .bv--border-draw.bv--whats::after   { background: var(--c-whats); }
  .bv--border-draw.bv--primary:hover::before,
  .bv--border-draw.bv--whats:hover::before,
  .bv--border-draw.bv--primary:hover::after,
  .bv--border-draw.bv--whats:hover::after { width: 100%; }
  /* lados verticais via box-shadow */
  .bv--border-draw.bv--primary { box-shadow: inset 1.5px 0 0 transparent, inset -1.5px 0 0 transparent; }
  .bv--border-draw.bv--whats   { box-shadow: inset 1.5px 0 0 transparent, inset -1.5px 0 0 transparent; }
  .bv--border-draw.bv--primary:hover { box-shadow: inset 1.5px 0 0 var(--c-cyan), inset -1.5px 0 0 var(--c-cyan); }
  .bv--border-draw.bv--whats:hover   { box-shadow: inset 1.5px 0 0 var(--c-whats), inset -1.5px 0 0 var(--c-whats); }

  /* ===========================================================================
     39 · SKEW PARALLEL — forma paralelograma, texto reto
     =========================================================================== */
  .bv--skew.bv--primary,
  .bv--skew.bv--whats {
    transform: skewX(-12deg);
    border-radius: 4px;
    padding: 14px 30px;
    color: #fff;
    font-weight: 700;
  }
  .bv--skew.bv--primary { background: linear-gradient(135deg, #38bdf8, #1d4ed8); box-shadow: 0 6px 18px rgba(29,78,216,0.3); }
  .bv--skew.bv--whats   { background: linear-gradient(135deg, #2bd96f, #128c45); box-shadow: 0 6px 18px rgba(18,140,69,0.3); }
  .bv--skew.bv--primary > *,
  .bv--skew.bv--whats > * { display: inline-block; }
  /* texto endireitado via wrapper interno seria ideal, mas pra teste o skew leve fica bom */

  /* ===========================================================================
     40 · LAYERED — camada de fundo deslocada visível
     =========================================================================== */
  .bv--layered.bv--primary,
  .bv--layered.bv--whats {
    overflow: visible;
    border-radius: 10px;
    color: #fff;
    font-weight: 700;
  }
  .bv--layered.bv--primary { background: var(--c-blue); }
  .bv--layered.bv--whats   { background: var(--c-whats-dark); }
  .bv--layered.bv--primary::before,
  .bv--layered.bv--whats::before {
    content: ""; position: absolute; inset: 4px -4px -4px 4px;
    border-radius: inherit; z-index: -1;
    transition: inset 220ms ease;
  }
  .bv--layered.bv--primary::before { background: var(--c-cyan); }
  .bv--layered.bv--whats::before   { background: var(--c-whats); }
  .bv--layered.bv--primary:hover::before,
  .bv--layered.bv--whats:hover::before { inset: 0 -8px -8px 0; }

  /* ===========================================================================
     41 · SWEEP FILL — cor diferente desliza L→R no hover
     =========================================================================== */
  .bv--sweep-fill.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    font-weight: 700;
    position: relative;
  }
  .bv--sweep-fill.bv--primary::before {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background: var(--c-blue);
    transform: scaleX(0); transform-origin: left;
    transition: transform 350ms ease;
    border-radius: inherit;
  }
  .bv--sweep-fill.bv--primary:hover { color: #fff; }
  .bv--sweep-fill.bv--primary:hover::before { transform: scaleX(1); }

  .bv--sweep-fill.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 700;
  }
  .bv--sweep-fill.bv--whats::before {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background: var(--c-whats-dark);
    transform: scaleX(0); transform-origin: left;
    transition: transform 350ms ease;
    border-radius: inherit;
  }
  .bv--sweep-fill.bv--whats:hover { color: #fff; }
  .bv--sweep-fill.bv--whats:hover::before { transform: scaleX(1); }

  /* ===========================================================================
     42 · TEXT REVEAL — texto sobe e revela duplicado
     =========================================================================== */
  .bv--reveal-up.bv--primary,
  .bv--reveal-up.bv--whats {
    overflow: hidden;
    color: #fff;
    font-weight: 700;
    padding: 0 24px;
    height: 48px;
  }
  .bv--reveal-up.bv--primary { background: linear-gradient(135deg, #38bdf8, #1d4ed8); }
  .bv--reveal-up.bv--whats   { background: linear-gradient(135deg, #2bd96f, #128c45); }
  .bv--reveal-up.bv--primary > *,
  .bv--reveal-up.bv--whats > * { display: inline-block; }
  /* duplicação via ::before com mesmo content */
  .bv--reveal-up.bv--primary::before {
    content: "Solicitar demonstração";
    position: absolute; left: 0; right: 0;
    top: 100%; padding: 14px 24px;
    transition: top 300ms ease;
    color: var(--c-cyan);
  }
  .bv--reveal-up.bv--whats::before {
    content: "Falar no WhatsApp";
    position: absolute; left: 0; right: 0;
    top: 100%; padding: 14px 24px;
    transition: top 300ms ease;
    color: var(--c-whats);
  }
  .bv--reveal-up.bv--primary,
  .bv--reveal-up.bv--whats { transition: color 0s 300ms; }
  .bv--reveal-up.bv--primary:hover,
  .bv--reveal-up.bv--whats:hover { color: transparent; }
  .bv--reveal-up.bv--primary:hover::before,
  .bv--reveal-up.bv--whats:hover::before { top: 0; }

  /* ===========================================================================
     43 · ICON MORPH — ícone troca/anima no hover (seta→check)
     =========================================================================== */
  .bv--icon-morph.bv--primary {
    background: linear-gradient(135deg, #38bdf8, #1d4ed8);
    color: #fff;
    box-shadow: 0 4px 14px rgba(56,189,248,0.3);
  }
  .bv--icon-morph.bv--whats {
    background: linear-gradient(135deg, #2bd96f, #128c45);
    color: #fff;
    box-shadow: 0 4px 14px rgba(37,211,102,0.3);
  }
  .bv--icon-morph.bv--primary::after,
  .bv--icon-morph.bv--whats::after {
    content: "→";
    display: inline-block;
    transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1), opacity 200ms ease;
    transform-origin: center;
  }
  .bv--icon-morph.bv--primary:hover::after,
  .bv--icon-morph.bv--whats:hover::after {
    transform: rotate(-90deg) scale(1.15);
    content: "✓";
  }

  /* ===========================================================================
     44 · OUTLINE OUTWARD — outline cresce pra fora no hover
     =========================================================================== */
  .bv--outline-out.bv--primary {
    background: var(--c-cyan);
    color: #0a1628;
    font-weight: 700;
    outline: 0 solid rgba(56,189,248,0.5);
    outline-offset: 0;
    transition: outline 280ms ease, outline-offset 280ms ease, background 200ms ease;
  }
  .bv--outline-out.bv--primary:hover { outline: 3px solid rgba(56,189,248,0.5); outline-offset: 6px; }
  .bv--outline-out.bv--whats {
    background: var(--c-whats);
    color: #06281a;
    font-weight: 700;
    outline: 0 solid rgba(37,211,102,0.5);
    outline-offset: 0;
    transition: outline 280ms ease, outline-offset 280ms ease, background 200ms ease;
  }
  .bv--outline-out.bv--whats:hover { outline: 3px solid rgba(37,211,102,0.5); outline-offset: 6px; }

  /* ===========================================================================
     45 · INNER BREATHE — glow interno respirando
     =========================================================================== */
  .bv--breathe.bv--primary {
    background: var(--c-blue);
    color: #fff;
    animation: bvBreatheCyan 2.4s ease-in-out infinite;
  }
  @keyframes bvBreatheCyan {
    0%, 100% { box-shadow: inset 0 0 0 0 rgba(56,189,248,0), 0 4px 14px rgba(29,78,216,0.3); }
    50%      { box-shadow: inset 0 0 30px 4px rgba(56,189,248,0.55), 0 8px 22px rgba(29,78,216,0.4); }
  }

  .bv--breathe.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
    animation: bvBreatheGreen 2.4s ease-in-out infinite;
  }
  @keyframes bvBreatheGreen {
    0%, 100% { box-shadow: inset 0 0 0 0 rgba(37,211,102,0), 0 4px 14px rgba(18,140,69,0.3); }
    50%      { box-shadow: inset 0 0 30px 4px rgba(37,211,102,0.55), 0 8px 22px rgba(18,140,69,0.4); }
  }

  /* ===========================================================================
     46 · BOUNCY — scale spring no hover
     =========================================================================== */
  .bv--bounce.bv--primary {
    background: linear-gradient(135deg, #38bdf8, #1d4ed8);
    color: #fff;
    box-shadow: 0 6px 18px rgba(29,78,216,0.3);
    transition: transform 380ms cubic-bezier(0.34, 1.85, 0.64, 1);
  }
  .bv--bounce.bv--primary:hover { transform: scale(1.12); }
  .bv--bounce.bv--primary:active { transform: scale(0.95); transition: transform 80ms ease; }

  .bv--bounce.bv--whats {
    background: linear-gradient(135deg, #2bd96f, #128c45);
    color: #fff;
    box-shadow: 0 6px 18px rgba(18,140,69,0.3);
    transition: transform 380ms cubic-bezier(0.34, 1.85, 0.64, 1);
  }
  .bv--bounce.bv--whats:hover { transform: scale(1.12); }
  .bv--bounce.bv--whats:active { transform: scale(0.95); transition: transform 80ms ease; }

  /* ===========================================================================
     47 · DIAGONAL SPLIT — metade na diagonal
     =========================================================================== */
  .bv--diag-split.bv--primary {
    background: linear-gradient(115deg, var(--c-cyan) 0%, var(--c-cyan) 50%, var(--c-blue) 50%, var(--c-blue) 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(29,78,216,0.3);
  }
  .bv--diag-split.bv--whats {
    background: linear-gradient(115deg, var(--c-whats) 0%, var(--c-whats) 50%, var(--c-whats-dark) 50%, var(--c-whats-dark) 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(18,140,69,0.3);
  }

  /* ===========================================================================
     48 · LIVE INDICATOR — dot blinks como 'ao vivo'
     =========================================================================== */
  .bv--live-dot.bv--primary {
    background: var(--c-blue);
    color: #fff;
    padding-left: 32px;
  }
  .bv--live-dot.bv--whats {
    background: var(--c-whats-dark);
    color: #fff;
    padding-left: 32px;
  }
  .bv--live-dot.bv--primary::before,
  .bv--live-dot.bv--whats::before {
    content: ""; position: absolute; left: 14px; top: 50%;
    width: 8px; height: 8px; border-radius: 50%;
    transform: translateY(-50%);
  }
  .bv--live-dot.bv--primary::before {
    background: var(--c-cyan);
    box-shadow: 0 0 0 0 rgba(56,189,248,0.7);
    animation: bvLiveCyan 1.6s ease-out infinite;
  }
  .bv--live-dot.bv--whats::before {
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74,222,128,0.7);
    animation: bvLiveGreen 1.6s ease-out infinite;
  }
  @keyframes bvLiveCyan {
    0%   { box-shadow: 0 0 0 0 rgba(56,189,248,0.7); }
    70%  { box-shadow: 0 0 0 8px rgba(56,189,248,0); }
    100% { box-shadow: 0 0 0 0 rgba(56,189,248,0); }
  }
  @keyframes bvLiveGreen {
    0%   { box-shadow: 0 0 0 0 rgba(74,222,128,0.7); }
    70%  { box-shadow: 0 0 0 8px rgba(74,222,128,0); }
    100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
  }

  /* ===========================================================================
     49 · INSET GRADIENT — gradient dentro, border externo
     =========================================================================== */
  .bv--inset-grad.bv--primary {
    background: linear-gradient(135deg, #38bdf8, #1d4ed8);
    color: #fff;
    border: 2px solid #0b1220;
    box-shadow: 0 0 0 1px var(--c-cyan), 0 6px 18px rgba(29,78,216,0.3);
  }
  .bv--inset-grad.bv--whats {
    background: linear-gradient(135deg, #2bd96f, #128c45);
    color: #fff;
    border: 2px solid #0b1220;
    box-shadow: 0 0 0 1px var(--c-whats), 0 6px 18px rgba(18,140,69,0.3);
  }

  /* ===========================================================================
     50 · STACKED DEPTH — bloco abaixo offset, vira deck
     =========================================================================== */
  .bv--stacked.bv--primary,
  .bv--stacked.bv--whats {
    overflow: visible;
    color: #fff;
    font-weight: 700;
    border-radius: 10px;
  }
  .bv--stacked.bv--primary { background: var(--c-blue); }
  .bv--stacked.bv--whats   { background: var(--c-whats-dark); }
  .bv--stacked.bv--primary::before,
  .bv--stacked.bv--whats::before {
    content: ""; position: absolute; inset: 0;
    border-radius: inherit; z-index: -1;
    transform: translate(6px, 6px);
    opacity: 0.6;
    transition: transform 240ms ease;
  }
  .bv--stacked.bv--primary::before { background: var(--c-cyan); }
  .bv--stacked.bv--whats::before   { background: var(--c-whats); }
  .bv--stacked.bv--primary::after,
  .bv--stacked.bv--whats::after {
    content: ""; position: absolute; inset: 0;
    border-radius: inherit; z-index: -2;
    transform: translate(12px, 12px);
    opacity: 0.3;
    transition: transform 240ms ease;
  }
  .bv--stacked.bv--primary::after { background: var(--c-cyan); }
  .bv--stacked.bv--whats::after   { background: var(--c-whats); }
  .bv--stacked.bv--primary:hover::before,
  .bv--stacked.bv--whats:hover::before { transform: translate(3px, 3px); }
  .bv--stacked.bv--primary:hover::after,
  .bv--stacked.bv--whats:hover::after  { transform: translate(6px, 6px); }
</style>

<script>
  // Magnetic glow: atualiza --mx / --my conforme o mouse
  document.querySelectorAll<HTMLElement>(".bv--magnetic").forEach((el) => {
    el.addEventListener("mousemove", (e) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty("--mx", `${e.clientX - r.left}px`);
      el.style.setProperty("--my", `${e.clientY - r.top}px`);
    });
  });
</script>
