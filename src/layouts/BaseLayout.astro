---
import "../styles/theme.css";
import "../styles/global.css";

import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const { title = "Vistopred" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>

    <!-- Theme — escolha do usuário persiste (localStorage). Fallback no SO.
         Anti-flash: roda antes do render pra evitar piscar tema errado. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("vp-theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var theme = saved || (prefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", theme);
        } catch (_) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>

    <!-- Fonts — 1 request consolidado (Inter + Material Symbols Outlined + Rounded). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>

  <body>
    {/* Fundo: linhas abstratas SVG suaves (curvas que cruzam o viewport).
        Fica atrás de tudo (z-index: -1) e fixo no viewport. */}
    <div class="bg-lines" aria-hidden="true">
      <svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice"
           xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bgLine1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#38bdf8" stop-opacity="0"/>
            <stop offset="50%" stop-color="#38bdf8" stop-opacity="1"/>
            <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="bgLine2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#1d4ed8" stop-opacity="0"/>
            <stop offset="50%" stop-color="#1d4ed8" stop-opacity="1"/>
            <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0"/>
          </linearGradient>
        </defs>
        {/* 5 curvas Bezier longas atravessando — espessuras e opacidades variam */}
        <path d="M -50 220 Q 400 120, 800 280 T 1650 200" stroke="url(#bgLine1)" stroke-width="1.2" fill="none"/>
        <path d="M -50 380 Q 500 480, 900 360 T 1650 440" stroke="url(#bgLine2)" stroke-width="1"   fill="none"/>
        <path d="M -50 560 Q 350 620, 750 540 T 1650 600" stroke="url(#bgLine1)" stroke-width="1.4" fill="none"/>
        <path d="M -50 740 Q 600 680, 1000 800 T 1650 720" stroke="url(#bgLine2)" stroke-width="1"   fill="none"/>
        <path d="M -50  90 Q 450 180, 850 100 T 1650 140" stroke="url(#bgLine1)" stroke-width="0.8" fill="none"/>
      </svg>
    </div>

    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
