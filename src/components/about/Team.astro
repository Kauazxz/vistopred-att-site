---
/**
 * Equipe VistoPred — cards compactos com monograma (iniciais) em vez
 * de ícone genérico. Cada inicial gera um gradiente cyan/azul.
 */
const team = [
  { name: "Luiz Araujo",      role: "Engenheiro / Sócio Fundador" },
  { name: "Arthur Gomes",     role: "Programador Senior / Sócio Fundador — Desenvolvedor" },
  { name: "Kauã Araujo",      role: "Programador Júnior / Desenvolvedor" },
  { name: "Magnum Carius",    role: "Sócio Fundador & Head de Marketing" },
  { name: "Robson Gaiofatto", role: "Engenheiro Civil & Especialista Técnico" },
  { name: "Patrick Pires",    role: "Engenheiro Civil & Especialista Técnico" },
  { name: "Isabel Araujo",    role: "Equipe VistoPred" },
  { name: "Kaike Araujo",     role: "Equipe VistoPred" },
];

// Pega as iniciais (primeiro + último nome). Ex: "Luiz Araujo" → "LA"
function initials(name: string): string {
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}
---

<section class="page-section team-section">
  <div class="page-container">
    <div class="page-section__head">
      <span class="page-section__eyebrow" data-reveal="up">Equipe</span>
      <h2 class="page-section__title" data-reveal="up" style="--reveal-delay: 80ms">
        Conheça nossa equipe
      </h2>
      <p class="page-section__sub" data-reveal="up" style="--reveal-delay: 160ms">
        Profissionais comprometidos com inovação, eficiência e qualidade em cada entrega.
      </p>
    </div>

    <div class="team-grid">
      {team.map((member, i) => (
        <article class="team-card" data-reveal="up" style={`--reveal-delay: ${i * 60}ms`}>
          <div class="team-avatar" aria-hidden="true">
            <span class="team-avatar__initials">{initials(member.name)}</span>
          </div>
          <h3 class="team-name">{member.name}</h3>
          <p class="team-role">{member.role}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .team-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    border-radius: 16px;
    padding: 24px 18px;
    background: rgba(255, 255, 255, 0.65);
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
                border-color 220ms ease, box-shadow 220ms ease;
    position: relative;
    overflow: hidden;
  }
  [data-theme="dark"] .team-card {
    background: rgba(20, 27, 46, 0.55);
    border-color: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
  }
  /* Acento gradient sutil no topo do card */
  .team-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.4), transparent);
  }
  .team-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--brand) 45%, transparent);
    box-shadow: 0 14px 32px rgba(56, 189, 248, 0.18);
  }

  /* Avatar com monograma — gradiente cyan/azul */
  .team-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #38bdf8 0%, #1d4ed8 100%);
    display: grid;
    place-items: center;
    margin: 0 auto 14px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 8px 24px -4px rgba(29, 78, 216, 0.4);
    position: relative;
  }
  /* Halo cyan suave ao redor */
  .team-avatar::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: radial-gradient(50% 50% at 50% 50%, rgba(56, 189, 248, 0.2), transparent 70%);
    z-index: -1;
    filter: blur(8px);
  }
  .team-avatar__initials {
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.02em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }

  .team-name {
    margin: 0;
    color: var(--text);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .team-role {
    margin: 6px 0 0;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.45;
  }

  /* === Responsivo === */
  @media (max-width: 1024px) {
    .team-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .team-avatar { width: 64px; height: 64px; }
    .team-avatar__initials { font-size: 20px; }
  }
  @media (max-width: 480px) {
    .team-card { padding: 20px 16px; }
  }
</style>
