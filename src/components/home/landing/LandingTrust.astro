---
const audience = [
  "Engenheiros civis",
  "Arquitetos",
  "Administradoras",
  "Síndicos profissionais",
  "Equipes de manutenção",
  "Construtoras",
];

const stats = [
  { value: "100%", label: "Relatórios padronizados" },
  { value: "+10", label: "Anos de experiência técnica" },
  { value: "24/7", label: "Acesso na nuvem" },
  { value: "0", label: "Papelada perdida" },
];
---

<section class="lp-section lp-trust">
  <div class="lp-container">
    <div class="lp-trust__grid">
      <div data-lp-reveal>
        <span class="lp-eyebrow">Para quem é</span>
        <h2 class="lp-h2">Feito para quem leva engenharia a sério</h2>
        <p class="lp-lead">
          O VistoPred é a ferramenta de quem precisa entregar laudos confiáveis, manter
          edificações funcionando e proteger seu patrimônio técnico — com profissionalismo,
          segurança e organização.
        </p>

        <div class="lp-trust__audience">
          {audience.map((a) => (
            <div class="lp-audience-chip">{a}</div>
          ))}
        </div>
      </div>

      <div class="lp-trust__stats" data-lp-reveal>
        {stats.map((s) => (
          <div class="lp-stat">
            <div class="lp-stat__value">{s.value}</div>
            <div class="lp-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
