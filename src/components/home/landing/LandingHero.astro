---
const whats = "https://wa.me/5524998773164";
---

<section class="lp-hero">
  <div class="lp-container">
    <div class="lp-hero__grid">
      <div class="lp-hero__copy">
        <span class="lp-eyebrow">Plataforma para inspeção e manutenção predial</span>
        <h1 class="lp-hero__title">
          Torne sua Gestão de Manutenção e Vistoria Predial
          <em>mais ágil e eficiente</em> com a nossa tecnologia
        </h1>
        <p class="lp-hero__sub">
          Atue em todas as etapas da sua gestão com mais eficiência e eficácia, através de uma
          solução simples, prática e de fácil compreensão.
        </p>
        <div class="lp-hero__ctas">
          <a class="lp-btn lp-btn--primary lp-btn--lg" href="/contato">Solicitar demonstração</a>
          <a class="lp-btn lp-btn--whats" href={whats} target="_blank" rel="noopener">
            Falar no WhatsApp
          </a>
        </div>
      </div>

      <div class="lp-hero__visual" aria-hidden="true">
        <div class="lp-phone">
          <div class="lp-phone__notch"></div>
          <div class="lp-phone__screen">
            <!-- Substitua o bloco abaixo pelo print real do app:
                 <img src="/images/home/seu-print.png" alt="VistoPred" /> -->
            <div class="lp-phone__placeholder">
              <div class="lp-phone__placeholder-icon">VP</div>
              <div class="lp-phone__placeholder-title">VistoPred</div>
              <div class="lp-phone__placeholder-hint">
                Coloque aqui o print real do app
              </div>
            </div>
          </div>
        </div>

        <div class="lp-floating lp-floating--1">
          <div class="lp-floating__icon">✓</div>
          <div>
            <div class="lp-floating__title">Checklist concluído</div>
            <div class="lp-floating__sub">12/12 itens vistoriados</div>
          </div>
        </div>

        <div class="lp-floating lp-floating--2">
          <div class="lp-floating__icon">📷</div>
          <div>
            <div class="lp-floating__title">48 fotos organizadas</div>
            <div class="lp-floating__sub">Por ambiente e pavimento</div>
          </div>
        </div>

        <div class="lp-floating lp-floating--3">
          <div class="lp-floating__icon">📄</div>
          <div>
            <div class="lp-floating__title">Relatório gerado</div>
            <div class="lp-floating__sub">PDF pronto em 30s</div>
          </div>
        </div>

        <div class="lp-floating lp-floating--4">
          <div class="lp-floating__icon">🔧</div>
          <div>
            <div class="lp-floating__title">Manutenção em dia</div>
            <div class="lp-floating__sub">7 tarefas previstas</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
