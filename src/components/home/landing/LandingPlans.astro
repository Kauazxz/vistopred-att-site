---
import { plans } from "../../../data/plans.ts";

const buildWhats = (planTitle: string) =>
  `https://wa.me/5524998773164?text=${encodeURIComponent(
    `Olá! Tenho interesse no ${planTitle}. Pode me enviar uma proposta?`
  )}`;
---

<section class="lp-section lp-plans" id="planos">
  <div class="lp-container">
    <div class="lp-section-head" data-lp-reveal>
      <span class="lp-eyebrow">Planos</span>
      <h2 class="lp-h2">Escolha o plano certo para o seu time</h2>
      <p class="lp-lead">
        De inspeções pontuais a gestão completa de administradoras — temos um plano para cada
        estágio. Solicite uma proposta personalizada.
      </p>
    </div>

    <div class="lp-plans__grid">
      {plans.map((plan) => (
        <article class={`lp-plan ${plan.highlight ? "lp-plan--highlight" : ""}`} data-lp-reveal>
          <div class="lp-plan__name">{plan.name}</div>
          <h3 class="lp-plan__title">{plan.title}</h3>
          <p class="lp-plan__desc">{plan.description}</p>
          <ul class="lp-plan__features">
            {plan.features.map((f) => <li>{f}</li>)}
          </ul>
          <a class="lp-btn lp-btn--primary lp-plan__cta" href={buildWhats(plan.title)} target="_blank" rel="noopener">
            Solicitar proposta
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
