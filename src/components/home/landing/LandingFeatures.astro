---
const features = [
  { icon: "📄", title: "Relatórios automáticos", text: "Geração instantânea em PDF com identidade da sua empresa." },
  { icon: "✓", title: "Checklists inteligentes", text: "Templates prontos e personalizáveis por tipo de inspeção." },
  { icon: "📷", title: "Registro fotográfico", text: "Fotos organizadas por ambiente, pavimento e edificação." },
  { icon: "📚", title: "Histórico da edificação", text: "Linha do tempo de tudo que já foi feito em cada imóvel." },
  { icon: "🔧", title: "Manutenção preventiva", text: "Agenda automática para nada passar despercebido." },
  { icon: "👥", title: "Gestão de equipes", text: "Funcionários, fornecedores e prestadores num só painel." },
  { icon: "🏗", title: "Obras e pós-obra", text: "Acompanhamento técnico do início ao fim do projeto." },
  { icon: "📊", title: "Painel técnico", text: "Visão geral de status, prazos e indicadores em tempo real." },
];
---

<section class="lp-section lp-features">
  <div class="lp-container">
    <div class="lp-section-head" data-lp-reveal>
      <span class="lp-eyebrow">Funcionalidades</span>
      <h2 class="lp-h2">Recursos pensados para o dia a dia técnico</h2>
      <p class="lp-lead">
        Cada funcionalidade do VistoPred resolve um problema real de quem cuida de edificações.
      </p>
    </div>

    <div class="lp-features__grid">
      {features.map((f) => (
        <article class="lp-feature" data-lp-reveal>
          <div class="lp-feature__icon">{f.icon}</div>
          <h3 class="lp-feature__title">{f.title}</h3>
          <p class="lp-feature__text">{f.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
