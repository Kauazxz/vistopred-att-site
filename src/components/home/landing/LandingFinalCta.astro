---
const whats = "https://wa.me/5524998773164?text=Ol%C3%A1!%20Quero%20conhecer%20o%20VistoPred.";
---

<section class="lp-final">
  <div class="lp-container">
    <div class="lp-final__inner" data-lp-reveal>
      <h2 class="lp-final__title">Pronto para profissionalizar sua gestão técnica?</h2>
      <p class="lp-final__sub">
        Agende uma demonstração gratuita ou fale agora com um consultor no WhatsApp.
      </p>
      <div class="lp-final__ctas">
        <a class="lp-btn lp-btn--primary lp-btn--lg" href="/contato">Solicitar demonstração</a>
        <a class="lp-btn lp-btn--whats lp-btn--lg" href={whats} target="_blank" rel="noopener">
          Falar no WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
