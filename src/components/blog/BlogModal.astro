<div class="blog-modal" id="blogModal" aria-hidden="true">
  <div class="blog-modal-card" role="dialog" aria-modal="true" aria-label="Prévia da postagem">
    <button class="blog-modal-close" id="blogModalClose" type="button" aria-label="Fechar">
      <span class="material-symbols-rounded">close</span>
    </button>

    <div class="blog-modal-cover">
      <img id="blogModalCover" alt="" />
      <span class="blog-badge" id="blogModalBadge">Categoria</span>
    </div>

    <div class="blog-modal-body">
      <h2 id="blogModalTitle"></h2>
      <p class="blog-modal-meta" id="blogModalMeta"></p>

      <p class="blog-modal-excerpt" id="blogModalExcerpt"></p>

      <div class="blog-modal-actions">
        <a class="btn-primary" id="blogModalLink" href="#">Ler postagem completa</a>
      </div>
    </div>
  </div>
</div>
